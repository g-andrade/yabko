% -*- mode: erlang; -*- vim: set ft=erlang:
[
    {config, [
        #{
            files => ["src/**/*.erl"],
            ruleset => erl_files,
            rules => [
                % Lowercase `is_*` guard-style macros are an intentional convention.
                {elvis_style, macro_naming_convention, #{
                    regex => "^([A-Z](_?[A-Z0-9]+)*|is_[a-z0-9_]+)$"
                }},
                % `xmlText` is xmerl's record tag, matched as a literal atom.
                {elvis_style, atom_naming_convention, #{
                    regex => "^((xmlText)|([a-z](_?[a-z0-9]+)*(_SUITE)?))$"
                }}
            ]
        },
        #{
            files => ["rebar.config", "elvis.config"],
            ruleset => rebar_config
        }
    ]}
].
